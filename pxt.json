{
    "name": "BKK-ROBOT",
    "version": "1.0.1",
    "description": "MakeCode extension for controlling a robot through Bluetooth UART",
    "dependencies": {
        "core": "*",
        "bluetooth": "*",
        "microphone": "*"
    },
    "files": [
        "main.blocks",
        "main.ts",
        "README.md"
    ],
    "testFiles": [
        "test.ts"
    ],
    "targetVersions": {
        "target": "9.0.5",
        "targetId": "microbit"
    },
    "supportedTargets": [
        "microbit"
    ],
    "preferredEditor": "tsprj",
    "yotta": {
        "config": {
            "microbit-dal": {
                "bluetooth": {
                    "open": 1,
                    "whitelist": 0,
                    "security_level": null
                }
            }
        }
    }
}
